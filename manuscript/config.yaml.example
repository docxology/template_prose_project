# template_prose_project — configuration TEMPLATE
#
# Copy this file to `config.yaml` and customize for your manuscript. The
# bundled `config.yaml` is intentionally permissive (FKGL band 10–18,
# citation floor 0.0) so the exemplar's own prose passes its own gate;
# this example shows the *stricter* defaults a real editorial review
# typically uses.
#
# Release workflow (Zenodo + GitHub): see docs/guides/publishing-guide.md and
# docs/guides/zenodo-doi-strategy.md for the split concept/version DOI layout.

paper:
  title: "Your Manuscript Title"
  subtitle: "Optional Subtitle"
  version: "1.0"   # Zenodo version field; GitHub release body version line
  # date: "2026-05-27"  # Optional; Zenodo publication_date (overrides publication.year)

authors:
  - name: "Your Name"
    orcid: "0000-0000-0000-0000"   # Zenodo creator ORCID — placeholder values are omitted at deposit
    email: "you@your.institution"
    affiliation: "Your Institution"   # Zenodo creator affiliation
    corresponding: true

publication:
  doi: ""    # Concept DOI — stable citation; PDF cover and CITATION.cff
  version_doi: ""  # Latest Zenodo version DOI (publish_project_release.py write-back target)
  version_record: ""  # Latest deposit record URL
  year: "2026"   # Zenodo publication_date when paper.date is absent
  repository_url: ""  # Optional; Zenodo related_identifiers when distinct from GitHub release
  zenodo_description: ""  # Optional override; skip auto plaintext render (footer still appended)
  github_repository: ""  # Optional; shown on transmission bookends before first GitHub release
  transmission_bookends:
    enabled: false  # Inject 00_00_transmission_begin.md / 99_zz_transmission_end.md into combined PDF
    max_prior_releases: 5  # Ledger cap; end bookend shows min(max_prior_releases, 3) rows for single-page fit
    show_steganography: true  # Summarize steganography config on bookend pages
  # deposit_filename:
  #   enabled: true  # Rename Zenodo/GitHub upload to Author_Year_Topic_hash8.pdf
  #   topic: ""  # optional override for the topic segment

keywords:
  - "your"
  - "manuscript"
  - "keywords"

metadata:
  license: "MIT"   # Zenodo license; also PDF publishing block
  language: "en"

# Abstract for deposits: manuscript/00_abstract.md (hydrated copy preferred from
# output/manuscript/00_abstract.md after analysis). Not a config key.

# Path to the manuscript directory, relative to project root.
manuscript_dir: "manuscript"

# ---------------------------------------------------------------------------
# Prose-analysis thresholds — STRICTER than the bundled config.
#
# These defaults reflect a typical "editorial review for a methods paper"
# stance: the prose should land between graduate-coursework difficulty
# (~grade 12) and dense-but-readable (~grade 16), and every 1000 words
# should average at least three citations. Tighten or relax to match
# your audience.
# ---------------------------------------------------------------------------
prose:
  # FKGL band the manuscript should land within. Tighter than bundled
  # (which is 10–18 so the exemplar's own methodological prose passes).
  target_grade_level_min: 12.0
  target_grade_level_max: 16.0

  # Words-per-sentence cutoff above which a sentence is flagged as long.
  # 30 is tighter than the bundled 35.
  long_sentence_threshold: 30

  # Minimum citations per 1000 words. 3.0 is a sane default for
  # methods/results sections of empirical papers.
  citation_density_min_per_1000: 3.0

  # Structural rules. Both default true. Flip to false if your manuscript
  # uses non-standard heading conventions.
  require_h1_per_section: true
  forbid_skipped_levels: true

# ---------------------------------------------------------------------------
# Bibliography cross-check.
# ---------------------------------------------------------------------------
bibliography:
  references_path: "manuscript/references.bib"
  fail_on_missing: true   # cited [@key] not in bib → fail
  fail_on_unused: true    # bib entry never cited → fail (stricter than bundled)

# ---------------------------------------------------------------------------
# Final markdown review report.
# ---------------------------------------------------------------------------
report:
  output_path: "output/review_report.md"
  include_per_file_table: true
  include_outline: true
  include_quality_flags: true

render:
  formats:
    pdf: true
    html: true
    slides: true
    docx: false
    epub: false
